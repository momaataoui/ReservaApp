<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Quand le mot de passe est VISIBLE (checked=true), on montre l'oeil ouvert -->
    <item android:state_checked="true" android:drawable="@drawable/ic_eye_open" />
    <!-- Quand le mot de passe est CACHÉ (checked=false), on montre l'oeil barré -->
    <item android:drawable="@drawable/ic_eye_closed" />
</selector>