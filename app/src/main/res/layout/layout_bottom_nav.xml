<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <!-- Global Top Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EBEBEB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- DISCOVER -->
        <LinearLayout
            android:id="@+id/navDiscover"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <View
                android:id="@+id/indicatorDiscover"
                android:layout_width="30dp"
                android:layout_height="1dp"
                android:background="@color/black"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/ivDiscover"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/ic_discover"
                android:contentDescription="Explore"
                android:tint="#717171" />

            <TextView
                android:id="@+id/tvDiscover"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textSize="10sp"
                android:textColor="#717171"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- WISHLISTS -->
        <LinearLayout
            android:id="@+id/navSaved"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <View
                android:id="@+id/indicatorSaved"
                android:layout_width="30dp"
                android:layout_height="1dp"
                android:background="@color/black"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/ivSaved"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/ic_wishlists"
                android:contentDescription="Wishlists"
                android:tint="#717171" />

            <TextView
                android:id="@+id/tvSaved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wishlists"
                android:textSize="10sp"
                android:textColor="#717171"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- BOOKINGS -->
        <LinearLayout
            android:id="@+id/navBookings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <View
                android:id="@+id/indicatorBookings"
                android:layout_width="30dp"
                android:layout_height="1dp"
                android:background="@color/black"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/ivBookings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/ic_bookings"
                android:contentDescription="Trips"
                android:tint="#717171" />

            <TextView
                android:id="@+id/tvBookings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trips"
                android:textSize="10sp"
                android:textColor="#717171"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <View
                android:id="@+id/indicatorProfile"
                android:layout_width="30dp"
                android:layout_height="1dp"
                android:background="@color/black"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/ivProfileNav"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/ic_profile"
                android:contentDescription="Profile"
                android:tint="#717171" />

            <TextView
                android:id="@+id/tvProfileNav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="10sp"
                android:textColor="#717171"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>