<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@color/white"
    android:elevation="16dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp">

    <LinearLayout
        android:id="@+id/navDiscover"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/nav_item_bg_selected"
        android:paddingVertical="8dp">
        <ImageView
            android:id="@+id/ivDiscover"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_discover"
            android:contentDescription="Discover" />
        <TextView
            android:id="@+id/tvDiscover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISCOVER"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#8B6B4F"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navBookings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ivBookings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bookings"
            android:alpha="0.5"
            android:contentDescription="Bookings" />
        <TextView
            android:id="@+id/tvBookings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BOOKINGS"
            android:textSize="10sp"
            android:alpha="0.5"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navSaved"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ivSaved"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_saved"
            android:alpha="0.5"
            android:contentDescription="Saved" />
        <TextView
            android:id="@+id/tvSaved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVED"
            android:textSize="10sp"
            android:alpha="0.5"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/ivProfileNav"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_profile"
            android:alpha="0.5"
            android:contentDescription="Profile" />
        <TextView
            android:id="@+id/tvProfileNav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROFILE"
            android:textSize="10sp"
            android:alpha="0.5"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</LinearLayout>