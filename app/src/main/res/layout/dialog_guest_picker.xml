<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <!-- ── Adultes ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adultes"
                android:textColor="#1A1A1A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13 ans et plus"
                android:textColor="#757575"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Bouton − -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdultMinus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="−"
            android:textSize="20sp"
            android:textColor="#1A1A1A"
            app:strokeColor="#CCCCCC"
            app:cornerRadius="20dp" />

        <TextView
            android:id="@+id/tvAdultsCount"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="2"
            android:gravity="center"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Bouton + -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdultPlus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A1A1A"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="20dp" />

    <!-- ── Enfants ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enfants"
                android:textColor="#1A1A1A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 à 12 ans"
                android:textColor="#757575"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Bouton − -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChildMinus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="−"
            android:textSize="20sp"
            android:textColor="#1A1A1A"
            app:strokeColor="#CCCCCC"
            app:cornerRadius="20dp" />

        <TextView
            android:id="@+id/tvChildrenCount"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:gravity="center"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Bouton + -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChildPlus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A1A1A"
            app:cornerRadius="20dp" />
    </LinearLayout>

</LinearLayout>