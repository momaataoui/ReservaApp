<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ReservaApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- Background and Accent colors -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSecondary">@color/black</item>
        <item name="colorTertiary">@color/black</item>
        <item name="colorAccent">@color/black</item>
        <item name="colorOutline">#E0E0E0</item>

        <!-- Font style: Clean and Simple -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Material 3 Input Field Colors -->
        <item name="colorPrimaryContainer">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/black</item>
        <item name="colorSecondaryContainer">#F5F5F5</item>

        <!-- 🔥 IMPORTANT : Removing the Purple/Violet selection and cursor completely -->
        <item name="android:colorControlActivated">@color/black</item>
        <item name="android:colorControlHighlight">#20000000</item>
        <item name="android:textCursorDrawable">@null</item>
        <item name="android:textColorHighlight">#40000000</item>

        <!-- Password toggle icon color -->
        <item name="passwordToggleTint">@color/black</item>

        <!-- Activer les transitions Material 3 -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>

        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">default</item>
    </style>

    <style name="Theme.ReservaApp" parent="Base.Theme.ReservaApp" />

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImageView">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="RoundedCorners8">
        <item name="cornerSize">8dp</item>
    </style>

    <!-- Styles for Suggested Destinations in Search Sheet -->
    <style name="DestinationItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="DestinationIconCardStyle">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="DestinationIconStyle">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="DestinationTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="DestinationTitleStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DestinationSubTitleStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#888888</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>